<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nirmansutra | Enterprise Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #0f172a; color: white; }
        .login-card { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid #334155; }
        input { background: #1e293b; border: 1px solid #334155; outline: none; transition: 0.2s; }
        input:focus { border-color: #ff7a00; ring: 2px solid #ff7a00; }
    </style>
</head>
<body class="h-screen flex items-center justify-center p-4">

    <div class="login-card w-full max-w-md p-8 rounded-3xl shadow-2xl">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-black tracking-tighter text-white">NIRMAN<span class="text-orange-500">SUTRA</span></h1>
            <p class="text-slate-400 text-xs font-bold uppercase tracking-[3px] mt-2">Field Intel Gateway</p>
        </div>

        <form id="loginForm" class="space-y-5">
            <div>
                <label class="text-[10px] font-bold text-slate-500 uppercase ml-1">Work Email</label>
                <input type="email" id="email" class="w-full p-4 rounded-xl mt-1 text-sm" placeholder="name@nirmansutra.com" required>
            </div>
            <div>
                <label class="text-[10px] font-bold text-slate-500 uppercase ml-1">Security Key</label>
                <input type="password" id="password" class="w-full p-4 rounded-xl mt-1 text-sm" placeholder="••••••••" required>
            </div>
            
            <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-4 rounded-xl shadow-lg shadow-orange-500/20 transition-all uppercase text-sm tracking-widest">
                Authorize Access
            </button>
        </form>

        <p id="errorMsg" class="text-red-400 text-center text-xs mt-4 font-bold hidden"></p>
    </div>

    <script src="https://www.gstatic.com/firebasejs/9.1.3/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.1.3/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.1.3/firebase-firestore-compat.js"></script>

    <script>
        // Replace with your Firebase config from V1
        const firebaseConfig = {
            apiKey: "YOUR_API_KEY",
            authDomain: "YOUR_PROJECT_ID.firebaseapp.com",
            projectId: "YOUR_PROJECT_ID",
            storageBucket: "YOUR_PROJECT_ID.appspot.com",
            messagingSenderId: "YOUR_SENDER_ID",
            appId: "YOUR_APP_ID"
        };

        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.firestore();

        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const errorEl = document.getElementById('errorMsg');

            try {
                // 1. Sign in with Firebase Auth
                const userCredential = await auth.signInWithEmailAndPassword(email, password);
                const user = userCredential.user;

                // 2. Fetch User Role from Firestore RBAC
                const userDoc = await db.collection("users").doc(user.uid).get();

                if (userDoc.exists) {
                    const userData = userDoc.data();
                    
                    // 3. Routing Logic based on Role
                    if (userData.role === "Admin" || userData.role === "SuperAdmin") {
                        window.location.href = "admin/dashboard.html";
                    } else {
                        window.location.href = "field/survey.html";
                    }
                } else {
                    errorEl.innerText = "Error: User permissions not found in Firestore.";
                    errorEl.classList.remove('hidden');
                }
            } catch (error) {
                errorEl.innerText = "Login Failed: Check your credentials.";
                errorEl.classList.remove('hidden');
            }
        });
    </script>
</body>
</html>
